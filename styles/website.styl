/* GitBook Custom Stylesheet for Brutus.finance */
/* Theme: Clean, Professional, Crypto-focused */

/* ============================================
   VARIABLES & CUSTOM PROPERTIES
   ============================================ */

:root {
    --color-primary: #1e3a5f;
    --color-primary-light: #2a5a8f;
    --color-primary-dark: #0f2440;
    --color-accent: #f7931a;
    --color-accent-light: #ffaa33;
    --color-bg: #fafbfc;
    --color-bg-dark: #1a1a2e;
    --color-text: #333333;
    --color-text-light: #666666;
    --color-border: #e0e6ed;
    --color-success: #27ae60;
    --color-warning: #f39c12;
    --color-danger: #e74c3c;
    --color-info: #3498db;
    --color-code-bg: #1e1e2e;
    --color-code-text: #a9b7c6;
    --font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    --font-mono: 'Fira Code', 'Consolas', 'Monaco', monospace;
    --border-radius: 8px;
    --shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    --shadow-hover: 0 4px 24px rgba(0, 0, 0, 0.12);
}

/* ============================================
   BASE STYLES
   ============================================ */

body {
    font-family: var(--font-family);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.7;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

/* ============================================
   HEADER & NAVIGATION
   ============================================ */

.book-header {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary)) !important;
    border-bottom: 3px solid var(--color-accent) !important;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.15) !important;
}

.book-header .book-brand {
    color: #ffffff !important;
    font-weight: 700;
    font-size: 1.2em;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.book-header .book-brand:hover {
    color: var(--color-accent) !important;
}

.book-header .book-logo img {
    max-height: 40px;
    border-radius: var(--border-radius);
}

.book-nav {
    background: var(--color-primary) !important;
}

.book-nav a {
    color: rgba(255, 255, 255, 0.85) !important;
    transition: all 0.3s ease;
    padding: 8px 16px !important;
    border-radius: var(--border-radius);
}

.book-nav a:hover,
.book-nav a.active {
    color: var(--color-accent) !important;
    background: rgba(255, 255, 255, 0.1) !important;
}

/* Language selector */
.book-header .dropdown-toggle {
    background: rgba(255, 255, 255, 0.15) !important;
    border: 1px solid rgba(255, 255, 255, 0.25) !important;
    color: #fff !important;
    border-radius: var(--border-radius) !important;
    padding: 6px 12px !important;
}

/* ============================================
   SIDEBAR / TABLE OF CONTENTS
   ============================================ */

.book-summary {
    background: #ffffff !important;
    border-right: 1px solid var(--color-border) !important;
    box-shadow: 2px 0 12px rgba(0, 0, 0, 0.04);
}

.book-summary .book-summary-title {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary)) !important;
    color: #ffffff !important;
    padding: 16px 24px !important;
    font-size: 1.1em !important;
    font-weight: 700 !important;
    border-bottom: 2px solid var(--color-accent) !important;
}

.book-summary a {
    color: var(--color-primary) !important;
    padding: 8px 16px !important;
    border-radius: var(--border-radius) !important;
    transition: all 0.2s ease;
}

.book-summary a:hover {
    background: rgba(30, 58, 95, 0.08) !important;
    color: var(--color-primary-light) !important;
}

.book-summary .active {
    background: rgba(30, 58, 95, 0.12) !important;
    color: var(--color-accent) !important;
    font-weight: 600;
    border-left: 3px solid var(--color-accent);
}

.book-summary .book-summary-item.expandable > a {
    font-weight: 600;
}

.book-summary .indent-1 a {
    padding-left: 32px !important;
}

.book-summary .indent-2 a {
    padding-left: 48px !important;
}

/* ============================================
   PAGE CONTENT
   ============================================ */

.book-body {
    background: var(--color-bg) !important;
}

.markdown-section {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 48px !important;
}

.markdown-section h1 {
    color: var(--color-primary-dark) !important;
    font-size: 2.2em !important;
    margin-top: 0 !important;
    margin-bottom: 8px !important;
    padding-bottom: 16px !important;
    border-bottom: 3px solid var(--color-accent) !important;
}

.markdown-section h2 {
    color: var(--color-primary) !important;
    font-size: 1.7em !important;
    margin-top: 40px !important;
    margin-bottom: 16px !important;
    padding-bottom: 8px !important;
    border-bottom: 1px solid var(--color-border) !important;
}

.markdown-section h3 {
    color: var(--color-primary-light) !important;
    font-size: 1.3em !important;
    margin-top: 32px !important;
    margin-bottom: 12px !important;
}

.markdown-section h4 {
    color: var(--color-text) !important;
    font-size: 1.1em !important;
    margin-top: 24px !important;
}

.markdown-section h5 {
    color: var(--color-text-light) !important;
    font-size: 1em !important;
    margin-top: 20px !important;
}

.markdown-section p {
    margin-bottom: 16px !important;
    line-height: 1.8;
}

/* ============================================
   CODE BLOCKS
   ============================================ */

.markdown-section pre {
    background: var(--color-code-bg) !important;
    border: 1px solid #2d2d3f !important;
    border-radius: var(--border-radius) !important;
    overflow-x: auto !important;
    box-shadow: var(--shadow) !important;
    margin: 20px 0 !important;
}

.markdown-section code {
    font-family: var(--font-mono) !important;
    background: rgba(30, 58, 95, 0.08) !important;
    color: var(--color-primary-dark) !important;
    padding: 2px 8px !important;
    border-radius: 4px !important;
    font-size: 0.9em !important;
    border: 1px solid var(--color-border) !important;
}

.markdown-section pre code {
    background: none !important;
    color: var(--color-code-text) !important;
    padding: 0 !important;
    border: none !important;
    font-size: 0.9em !important;
    line-height: 1.6;
}

.markdown-section .copy-btn {
    background: var(--color-primary) !important;
    color: #fff !important;
    border: none !important;
    border-radius: var(--border-radius) !important;
    padding: 4px 12px !important;
    cursor: pointer;
    transition: background 0.3s ease;
}

.markdown-section .copy-btn:hover {
    background: var(--color-accent) !important;
    color: var(--color-primary-dark) !important;
}

/* ============================================
   TABLES
   ============================================ */

.markdown-section table {
    border-collapse: collapse !important;
    width: 100% !important;
    margin: 24px 0 !important;
    border-radius: var(--border-radius) !important;
    overflow: hidden !important;
    box-shadow: var(--shadow) !important;
    font-size: 0.95em !important;
}

.markdown-section th {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary)) !important;
    color: #ffffff !important;
    font-weight: 600 !important;
    padding: 14px 16px !important;
    text-align: left !important;
    border: none !important;
    font-size: 0.95em !important;
}

.markdown-section td {
    padding: 12px 16px !important;
    border-bottom: 1px solid var(--color-border) !important;
    background: #ffffff !important;
    vertical-align: top !important;
}

.markdown-section tr:last-child td {
    border-bottom: none !important;
}

.markdown-section tr:hover td {
    background: rgba(30, 58, 95, 0.04) !important;
}

/* ============================================
   LINKS
   ============================================ */

.markdown-section a {
    color: var(--color-accent) !important;
    text-decoration: none !important;
    transition: all 0.2s ease;
    border-bottom: 1px solid transparent !important;
}

.markdown-section a:hover {
    color: var(--color-primary-light) !important;
    border-bottom-color: var(--color-accent) !important;
    text-decoration: none !important;
}

/* ============================================
   BLOCKQUOTES
   ============================================ */

.markdown-section blockquote {
    border-left: 4px solid var(--color-accent) !important;
    background: linear-gradient(90deg, rgba(247, 147, 26, 0.05), transparent) !important;
    padding: 16px 20px !important;
    margin: 20px 0 !important;
    border-radius: 0 var(--border-radius) var(--border-radius) 0 !important;
    font-style: italic;
    color: var(--color-text-light) !important;
}

.markdown-section blockquote p {
    margin-bottom: 0 !important;
    font-size: 1.05em !important;
}

/* ============================================
   LISTS
   ============================================ */

.markdown-section ul,
.markdown-section ol {
    margin: 16px 0 !important;
    padding-left: 28px !important;
}

.markdown-section li {
    margin-bottom: 8px !important;
    line-height: 1.7;
}

.markdown-section li p {
    margin-bottom: 0 !important;
}

.markdown-section li::marker {
    color: var(--color-accent);
}

/* ============================================
   ADMONITIONS / CALLOUTS
   ============================================ */

.markdown-section .admonition {
    border-radius: var(--border-radius) !important;
    padding: 16px 20px !important;
    margin: 20px 0 !important;
    border-left: 4px solid !important;
    box-shadow: var(--shadow) !important;
}

.markdown-section .admonition-title {
    font-weight: 700 !important;
    margin-top: 0 !important;
    font-size: 1.05em !important;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* Warning / Aviso */
.markdown-section .admonition.warning {
    background: #fff3cd !important;
    border-color: var(--color-warning) !important;
}

.markdown-section .admonition.warning .admonition-title {
    color: #856404 !important;
}

/* Info */
.markdown-section .admonition.info {
    background: #d1ecf1 !important;
    border-color: var(--color-info) !important;
}

.markdown-section .admonition.info .admonition-title {
    color: #0c5460 !important;
}

/* Tip */
.markdown-section .admonition.tip {
    background: #d4edda !important;
    border-color: var(--color-success) !important;
}

.markdown-section .admonition.tip .admonition-title {
    color: #155724 !important;
}

/* Danger */
.markdown-section .admonition.danger {
    background: #f8d7da !important;
    border-color: var(--color-danger) !important;
}

.markdown-section .admonition.danger .admonition-title {
    color: #721c24 !important;
}

/* ============================================
   HEADERS WITH ICONS (Custom)
   ============================================ */

.markdown-section h1::before,
h1[id]::before {
    margin-right: 12px;
}

/* ============================================
   FOOTER
   ============================================ */

.book-footer {
    background: var(--color-bg-dark) !important;
    color: rgba(255, 255, 255, 0.7) !important;
    border-top: 3px solid var(--color-accent) !important;
    padding: 24px 48px !important;
}

.book-footer a {
    color: var(--color-accent) !important;
}

.book-footer a:hover {
    color: var(--color-accent-light) !important;
}

/* ============================================
   BUTTONS & INTERACTIVE ELEMENTS
   ============================================ */

.markdown-section .btn {
    background: var(--color-primary) !important;
    color: #fff !important;
    border: none !important;
    padding: 10px 24px !important;
    border-radius: var(--border-radius) !important;
    font-weight: 600 !important;
    cursor: pointer;
    transition: all 0.3s ease !important;
    text-decoration: none !important;
    display: inline-block !important;
}

.markdown-section .btn:hover {
    background: var(--color-accent) !important;
    color: var(--color-primary-dark) !important;
    transform: translateY(-1px);
    box-shadow: var(--shadow-hover);
}

/* ============================================
   SEARCH
   ============================================ */

.book-search .search-input {
    border: 2px solid var(--color-border) !important;
    border-radius: var(--border-radius) !important;
    padding: 8px 16px !important;
    font-size: 0.95em !important;
    transition: border-color 0.3s ease;
}

.book-search .search-input:focus {
    border-color: var(--color-primary) !important;
    outline: none !important;
}

.book-search .search-results {
    border: 1px solid var(--color-border) !important;
    border-radius: var(--border-radius) !important;
    box-shadow: var(--shadow) !important;
}

.book-search .search-results .search-result {
    padding: 10px 16px !important;
    transition: background 0.2s ease;
}

.book-search .search-results .search-result:hover {
    background: rgba(30, 58, 95, 0.05) !important;
}

/* ============================================
   RESPONSIVE DESIGN
   ============================================ */

@media (max-width: 768px) {
    .markdown-section {
        padding: 24px 20px !important;
    }

    .markdown-section h1 {
        font-size: 1.8em !important;
    }

    .markdown-section h2 {
        font-size: 1.4em !important;
    }

    .markdown-section table {
        font-size: 0.85em !important;
    }

    .book-header .book-brand {
        font-size: 1em !important;
    }
}

/* ============================================
   PRINT STYLES
   ============================================ */

@media print {
    .book-header,
    .book-summary,
    .book-nav {
        display: none !important;
    }

    .markdown-section {
        padding: 0 !important;
        max-width: 100% !important;
    }

    .markdown-section pre {
        background: #f5f5f5 !important;
        border: 1px solid #ddd !important;
    }

    .markdown-section code {
        background: #f5f5f5 !important;
    }
}

/* ============================================
   ANIMATIONS
   ============================================ */

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.markdown-section > *:first-child {
    animation: fadeIn 0.3s ease;
}

/* ============================================
   SCROLLBAR CUSTOMIZATION (Webkit)
   ============================================ */

.markdown-section::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

.markdown-section::-webkit-scrollbar-track {
    background: var(--color-bg);
}

.markdown-section::-webkit-scrollbar-thumb {
    background: var(--color-primary-light);
    border-radius: 4px;
}

.markdown-section::-webkit-scrollbar-thumb:hover {
    background: var(--color-accent);
}