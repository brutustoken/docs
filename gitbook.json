{
  "title": "Brutus.finance",
  "description": "Documentación completa del ecosistema financiero descentralizado de Brutus.finance en la blockchain de Tron",
  "author": "Brutus Finance Team",
  "structure": {
    "readme": "README.md",
    "glossary": "GLOSSARY.md",
    "summary": "SUMMARY.md"
  },
  "styles": {
    "website": "styles/website.styl"
  },
  "plugins": [
    "back-to-top-button",
    "copy-code-button",
    "splitter",
    "-lunr",
    "-search",
    "search-pro"
  ],
  "pluginsConfig": {
    "search-pro": {
      "cutWord": true
    },
    "splitter": {
      "availWidth": 0,
      "minWidth": 600
    }
  },
  "variables": {
    "version": "2.7.1",
    "year": "2026"
  },
  "output": {
    "dir": "_book",
    "file": "index.html",
    "kindlegen": ""
  },
  "pdf": {
    "pageNumbers": true,
    "fontSize": 12,
    "fontFamily": "Arial",
    "paperSize": "a4",
    "margin": {
      "right": 62,
      "left": 62,
      "top": 56,
      "bottom": 56
    }
  }
}